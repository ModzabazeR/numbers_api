{
  "version": 2,
  "name": "numbers-api",
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/graphql",
      "dest": "app.js"
    },
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ],
  "functions": {
    "app.js": {
      "includeFiles": ["models/**", "views/**", "public/**", "README.md"]
    }
  }
}
